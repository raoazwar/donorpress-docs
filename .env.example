# Local WordPress site URL — Laragon default shown.
# No trailing slash.
WP_BASE_URL=http://donorpress.test

# WP admin credentials (test site only — never commit real ones).
WP_ADMIN_USER=admin
WP_ADMIN_PASS=password

# Optional: a logged-in donor account used for frontend dashboard screenshots.
# Leave blank to skip frontend logged-in captures.
WP_DONOR_USER=
WP_DONOR_PASS=

# Optional: the slug of a published page that contains [donorpress_form id="..."].
# Used for the donation-form frontend screenshot.
DONATION_FORM_SLUG=donate

# Optional: the slug of a published page that contains [donorpress_dashboard].
# Used for the donor-dashboard frontend screenshot.
DONOR_DASHBOARD_SLUG=my-donations
